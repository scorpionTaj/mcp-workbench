# Environment Variables Configuration

# Database
DATABASE_URL="file:./prisma/dev.db"

# Security - CRITICAL: Change these in production!
# Generate a strong random key for encryption (at least 32 characters)
# Example: openssl rand -base64 32
ENCRYPTION_KEY="your-super-secret-encryption-key-change-in-production"

# CORS - Set to your production domain
ALLOWED_ORIGIN="http://localhost:3000"

# Node Environment
NODE_ENV="development"
